<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Stage Prep — Pre-Gig Checklist</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<style is:global>
:root {
  --bg: #07080c;
  --surface: #0f1018;
  --surface2: #161822;
  --gold: #d4a853;
  --gold-dim: #9a7a3a;
  --gold-bright: #f0c95a;
  --green: #8fd49b;
  --text: #d8d4cc;
  --text-dim: #706c68;
  --text-mid: #9a968e;
  --text-bright: #f0ece4;
  --border: #252838;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'DM Sans', sans-serif;
  line-height: 1.55;
  min-height: 100vh;
  -webkit-tap-highlight-color: transparent;
}

.container { max-width: 920px; margin: 0 auto; padding: 32px 20px 60px; }

header {
  text-align: center;
  padding: 24px 0 28px;
  border-bottom: 1px solid var(--border);
  margin-bottom: 32px;
}
h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(34px, 6vw, 54px);
  font-weight: 900;
  color: var(--gold);
  letter-spacing: 1px;
  line-height: 1.1;
}
h1 .sub {
  display: block;
  font-size: 0.32em;
  font-family: 'JetBrains Mono', monospace;
  font-weight: 400;
  color: var(--text-dim);
  letter-spacing: 5px;
  text-transform: uppercase;
  margin-top: 12px;
}

.toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
  margin-bottom: 20px;
  flex-wrap: wrap;
}
.progress {
  font-family: 'JetBrains Mono', monospace;
  font-size: 13px;
  color: var(--text-mid);
}
.progress b { color: var(--gold-bright); font-weight: 600; }
.btn {
  background: transparent;
  color: var(--gold);
  border: 1px solid var(--gold-dim);
  padding: 8px 14px;
  border-radius: 6px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  cursor: pointer;
  letter-spacing: 0.5px;
  transition: background 0.15s, color 0.15s;
}
.btn:hover, .btn:active { background: var(--gold); color: var(--bg); }

.grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 14px;
}

.item {
  background: var(--surface);
  border: 1px solid var(--border);
  border-left: 3px solid var(--gold-dim);
  border-radius: 10px;
  padding: 22px 18px 18px;
  cursor: pointer;
  position: relative;
  user-select: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  transition: border-color 0.15s, background 0.15s, transform 0.1s;
}
.item:hover { background: var(--surface2); border-color: var(--gold-dim); }
.item:active { transform: scale(0.98); }

.item .icon {
  width: 72px;
  height: 72px;
  color: var(--gold);
  margin-bottom: 14px;
  transition: color 0.15s, opacity 0.15s;
}
.item .icon svg { width: 100%; height: 100%; display: block; }

.item .label {
  font-family: 'Playfair Display', serif;
  font-size: 19px;
  color: var(--gold);
  margin-bottom: 4px;
  line-height: 1.2;
}
.item .sub-text {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: var(--text-dim);
  letter-spacing: 0.5px;
}

.check {
  position: absolute;
  top: 10px;
  right: 10px;
  width: 22px;
  height: 22px;
  border: 1.5px solid var(--border);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface);
  transition: border-color 0.15s, background 0.15s;
}
.check svg {
  width: 14px;
  height: 14px;
  stroke: var(--bg);
  stroke-width: 3;
  fill: none;
  stroke-linecap: round;
  stroke-linejoin: round;
  opacity: 0;
  transform: scale(0.6);
  transition: opacity 0.15s, transform 0.15s;
}

.item.done {
  background: var(--surface2);
  border-left-color: var(--green);
}
.item.done .icon { color: var(--text-dim); opacity: 0.55; }
.item.done .label { color: var(--text-mid); text-decoration: line-through; text-decoration-color: var(--text-dim); }
.item.done .sub-text { color: var(--text-dim); }
.item.done .check {
  border-color: var(--green);
  background: var(--green);
}
.item.done .check svg { opacity: 1; transform: scale(1); }

.note {
  margin-top: 36px;
  padding: 18px 20px;
  background: var(--surface);
  border: 1px dashed var(--border);
  border-radius: 8px;
  color: var(--text-mid);
  font-size: 13.5px;
  line-height: 1.6;
}
.note b { color: var(--gold); font-weight: 600; }

.bottom-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 48px;
  padding-top: 22px;
  border-top: 1px solid var(--border);
  font-family: 'JetBrains Mono', monospace;
  font-size: 13px;
}
.bottom-nav a {
  color: var(--gold);
  text-decoration: none;
  padding: 8px 14px;
  border: 1px solid var(--gold-dim);
  border-radius: 6px;
  transition: background 0.15s, color 0.15s;
}
.bottom-nav a:hover { background: var(--gold); color: var(--bg); }

/* ── FLOATING BACK-TO-HUB ── */
.home-btn {
  position: fixed;
  bottom: calc(18px + env(safe-area-inset-bottom));
  right: calc(18px + env(safe-area-inset-right));
  z-index: 50;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 9px 14px;
  background: rgba(15, 16, 24, 0.92);
  border: 1px solid var(--gold-dim);
  border-radius: 999px;
  color: var(--gold);
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  text-decoration: none;
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  box-shadow: 0 4px 14px rgba(0, 0, 0, 0.4);
  transition: background 0.2s, color 0.2s, border-color 0.2s, transform 0.15s;
}
.home-btn:hover, .home-btn:focus-visible {
  background: var(--gold);
  color: var(--bg);
  border-color: var(--gold);
  transform: translateY(-1px);
  outline: none;
}
.home-btn .arrow { font-size: 13px; line-height: 1; }
@media print { .home-btn { display: none; } }

@media (max-width: 480px) {
  .grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
  .item { padding: 18px 10px 14px; }
  .item .icon { width: 56px; height: 56px; margin-bottom: 10px; }
  .item .label { font-size: 16px; }
  .home-btn {
    padding: 8px 12px;
    font-size: 10px;
    bottom: calc(14px + env(safe-area-inset-bottom));
    right: calc(14px + env(safe-area-inset-right));
  }
}
</style>
  <link rel="icon" type="image/svg+xml" href="/bass/favicon.svg">
