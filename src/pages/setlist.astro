function songTitleOf(card) {
  const el = card.querySelector('.stitle');
  return el ? el.textContent.replace(/★/g, '').trim() : '';
}

function injectMedia() {
  document.querySelectorAll('.card').forEach(card => {
    const entry = SONG_MEDIA[songTitleOf(card)];
    if (!entry) return;
    const inner = card.querySelector('.cinner');
    if (!inner) return;
    const row = document.createElement('div');
    row.className = 'media-row';
    const parts = [];
    if (entry.drive) {
      parts.push(`<button type="button" class="play-btn" data-drive="${entry.drive}" data-video="${entry.video ? '1' : '0'}">▶ Play ${entry.video ? 'video' : 'audio'}</button>`);
    } else {
      parts.push(`<span class="media-missing">No recording in Drive</span>`);
    }
    if (entry.spotify) {
      parts.push(`<a class="spotify-btn" href="https://open.spotify.com/search/${encodeURIComponent(entry.spotify)}" target="_blank" rel="noopener">♫ Spotify ↗</a>`);
    }
    row.innerHTML = parts.join('');
    inner.insertBefore(row, inner.firstChild);
  });
}

document.addEventListener('click', (e) => {
  const btn = e.target.closest('.play-btn');
  if (!btn) return;
  const id = btn.dataset.drive;
  const isVideo = btn.dataset.video === '1';
  const iframe = document.createElement('iframe');
  iframe.src = `https://drive.google.com/file/d/${id}/preview`;
  iframe.className = 'drive-player ' + (isVideo ? 'video' : 'audio');
  iframe.allow = 'autoplay';
  iframe.loading = 'lazy';
  btn.replaceWith(iframe);
});

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', injectMedia);
} else {
  injectMedia();
}
</script>
