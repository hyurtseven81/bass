<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Stage Setlist — Hüseyin</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Nunito:wght@300;400;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<style is:global>
:root {
  --bg: #07070f;
  --surface: #0f0f1c;
  --surface2: #161628;
  --border: #1e1e38;
  --gold: #d4a853;
  --gold-dim: #9a7535;
  --gold-bright: #f0c76a;
  --text: #ddd8c8;
  --text-dim: #7a7468;
  --text-bright: #f4f0e4;
  --green: #4ade80;
  --blue: #60a5fa;
  --star: #f59e0b;
  --red: #f87171;
  --purple: #a78bfa;
  --radius: 10px;
  --radius-sm: 6px;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
html { font-size: 16px; -webkit-text-size-adjust: 100%; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Nunito', sans-serif;
  padding-bottom: 60px;
  -webkit-tap-highlight-color: transparent;
  overflow-x: hidden;
}

/* ── HEADER ── */
.hdr {
  background: linear-gradient(160deg,#0c0c22 0%,#10102a 100%);
  border-bottom: 2px solid var(--gold-dim);
  padding: 14px 16px 10px;
}
.hdr-top { display:flex; align-items:center; justify-content:space-between; margin-bottom:8px; }
.hdr h1 { font-family:'Bebas Neue',sans-serif; font-size:2rem; color:var(--gold); letter-spacing:3px; line-height:1; }
.hdr-meta { font-size:0.68rem; color:var(--text-dim); letter-spacing:1px; text-align:right; line-height:1.7; text-transform:uppercase; }
.nav { display:flex; gap:6px; overflow-x:auto; scrollbar-width:none; padding-bottom:2px; }
.nav::-webkit-scrollbar { display:none; }
.nbtn {
  background:transparent; border:1px solid var(--border); color:var(--text-dim);
  font-family:'Bebas Neue',sans-serif; font-size:0.82rem; letter-spacing:1.5px;
  padding:5px 12px; border-radius:20px; cursor:pointer; white-space:nowrap;
  transition:all .2s; flex-shrink:0; min-height:32px;
}
.nbtn:hover,.nbtn.ao { border-color:var(--green); color:var(--green); background:rgba(74,222,128,.08); }
.nbtn.ac { border-color:var(--blue); color:var(--blue); background:rgba(96,165,250,.08); }
.nbtn.act { border-color:var(--gold); color:var(--gold); background:rgba(212,168,83,.08); }

/* ── SEARCH ── */
.srch { padding:8px 12px 4px; }
.srch input {
  width:100%; background:var(--surface); border:1px solid var(--border);
  border-radius:20px; color:var(--text); font-family:'Nunito',sans-serif;
  font-size:0.9rem; padding:8px 16px; outline:none; transition:border-color .2s;
}
.srch input:focus { border-color:var(--gold-dim); }
.srch input::placeholder { color:var(--text-dim); }

/* ── LEGEND ── */
.legend {
  display:flex; gap:14px; padding:6px 16px;
  background:var(--surface); border-bottom:1px solid var(--border);
  flex-wrap:wrap;
}
.leg { display:flex; align-items:center; gap:4px; font-size:0.65rem; color:var(--text-dim); letter-spacing:.5px; }
.ldot { width:7px; height:7px; border-radius:50%; }

/* ── SECTION ── */
.section { padding:0 10px; margin-top:12px; }
.sec-hdr { display:flex; align-items:center; gap:10px; padding:8px 6px 6px; margin-bottom:6px; }
.sec-title { font-family:'Bebas Neue',sans-serif; font-size:1.4rem; letter-spacing:4px; }
.sec-title.orig { color:var(--green); }
.sec-title.cov { color:var(--blue); }
.sec-cnt { font-size:0.7rem; color:var(--text-dim); background:var(--surface2); padding:2px 8px; border-radius:10px; letter-spacing:1px; }

/* ── SONG CARD ── */
.card {
  background:var(--surface); border:1px solid var(--border);
  border-radius:var(--radius); margin-bottom:8px; overflow:hidden;
  transition:border-color .2s;
}
.card.star { border-left:3px solid var(--star); }
.card.orig-c { border-left:3px solid var(--green); }
.card.cov-c { border-left:3px solid var(--blue); }
.card.star.orig-c,.card.star.cov-c { border-left:3px solid var(--star); }
.card.missing { opacity:.7; }

.card-hdr {
  display:flex; align-items:center; gap:8px;
  padding:11px 12px; cursor:pointer; user-select:none; -webkit-user-select:none;
  min-height:52px;
}
.snum { font-family:'JetBrains Mono',monospace; font-size:0.7rem; color:var(--text-dim); min-width:26px; text-align:right; flex-shrink:0; }
.smain { flex:1; min-width:0; }
.stitle { font-size:0.95rem; font-weight:700; color:var(--text-bright); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; line-height:1.2; }
.sartist { font-size:0.68rem; color:var(--text-dim); margin-top:1px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.sright { display:flex; align-items:center; gap:6px; flex-shrink:0; }
.kbadge {
  font-family:'Bebas Neue',sans-serif; font-size:1.05rem; letter-spacing:1px;
  color:var(--gold); background:rgba(212,168,83,.12); border:1px solid rgba(212,168,83,.3);
  padding:2px 7px; border-radius:var(--radius-sm); min-width:38px; text-align:center; line-height:1.5;
}
.dbadge { font-family:'JetBrains Mono',monospace; font-size:0.65rem; color:var(--text-dim); background:var(--surface2); padding:2px 5px; border-radius:4px; }
.bpm { font-family:'JetBrains Mono',monospace; font-size:0.65rem; color:var(--red); background:rgba(248,113,113,.1); border:1px solid rgba(248,113,113,.3); padding:2px 5px; border-radius:4px; }
.staricon { color:var(--star); font-size:0.9rem; }
.xicon { color:var(--text-dim); font-size:0.75rem; transition:transform .25s; flex-shrink:0; }
.card.open .xicon { transform:rotate(180deg); }

/* ── CARD BODY ── */
.cbody { max-height:0; overflow:hidden; transition:max-height .35s ease; }
.card.open .cbody { max-height:1200px; }
.cinner { border-top:1px solid var(--border); padding:12px 12px; display:flex; flex-direction:column; gap:10px; }

/* ── INFO BLOCKS ── */
.irow { display:flex; gap:6px; flex-wrap:wrap; }
.iblk { flex:1; min-width:130px; background:var(--surface2); border-radius:var(--radius-sm); padding:7px 9px; }
.ilabel { font-size:0.58rem; color:var(--gold-dim); letter-spacing:1.5px; text-transform:uppercase; font-weight:700; margin-bottom:3px; }
.ival { font-family:'JetBrains Mono',monospace; font-size:0.75rem; color:var(--text-bright); line-height:1.5; }
.ival.sc { color:var(--gold-bright); font-size:0.78rem; font-weight:600; letter-spacing:.5px; }
.itip { font-size:0.62rem; color:var(--text-dim); font-style:italic; margin-top:3px; line-height:1.45; letter-spacing:.2px; }
.itip b { color:var(--purple); font-style:normal; font-weight:600; }

/* ── CHORD CHART ── */
.chord-chart {
  background:#0a0a18; border:1px solid var(--border); border-radius:var(--radius-sm);
  padding:10px 12px; overflow-x:auto;
}
.chord-chart .sec-lbl {
  font-family:'Bebas Neue',sans-serif; font-size:0.78rem; letter-spacing:3px;
  color:var(--blue); margin-bottom:6px; margin-top:8px; display:block;
}
.chord-chart .sec-lbl:first-child { margin-top:0; }
.chord-line {
  font-family:'JetBrains Mono',monospace; font-size:0.82rem;
  color:var(--gold-bright); line-height:1.4; white-space:pre-wrap;
  word-break:break-all;
}
.lyric-line {
  font-size:0.78rem; color:var(--text); line-height:1.4;
  margin-bottom:5px; white-space:pre-wrap; word-break:break-all;
}
.chord-note { font-size:0.72rem; color:var(--purple); font-style:italic; margin-top:4px; }

/* ── BASS TIPS ── */
.bass {
  background:rgba(30,58,92,.3); border-left:2px solid var(--blue);
  border-radius:0 var(--radius-sm) var(--radius-sm) 0; padding:8px 10px;
}
.bass .ilabel { color:var(--blue); }
.bass-txt { font-size:0.8rem; color:var(--text); line-height:1.5; }

/* ── SPECIAL NOTES ── */
.snote {
  background:rgba(42,92,60,.2); border-left:2px solid var(--green);
  border-radius:0 var(--radius-sm) var(--radius-sm) 0; padding:7px 10px;
  font-size:0.76rem; color:var(--text); line-height:1.4;
}
.snote .ilabel { color:var(--green); }

/* ── MODULATION ALERT ── */
.mod-alert {
  background:rgba(245,158,11,.1); border:1px solid rgba(245,158,11,.35);
  border-radius:var(--radius-sm); padding:7px 10px;
  font-size:0.8rem; color:var(--star); font-weight:700; line-height:1.4;
}

/* ── KEY ALERT (key discrepancy) ── */
.key-alert {
  background:rgba(167,139,250,.1); border:1px solid rgba(167,139,250,.3);
  border-radius:var(--radius-sm); padding:6px 10px;
  font-size:0.74rem; color:var(--purple); line-height:1.4;
}

/* ── TAGS ── */
.tag {
  display:inline-block; font-size:0.6rem; font-weight:700; letter-spacing:1px;
  text-transform:uppercase; padding:2px 5px; border-radius:3px; margin-right:3px;
}
.ti { background:rgba(212,168,83,.15); color:var(--gold); }
.ts { background:rgba(248,113,113,.15); color:var(--red); }
.tw { background:rgba(96,165,250,.15); color:var(--blue); }
.tm { background:rgba(167,139,250,.15); color:var(--purple); }
.tr { background:rgba(74,222,128,.15); color:var(--green); }
.tmod { background:rgba(245,158,11,.2); color:var(--star); }

/* ── MISSING PLACEHOLDER ── */
.missing-placeholder {
  background:rgba(122,116,104,.08); border:1px dashed var(--border);
  border-radius:var(--radius-sm); padding:10px 12px;
  font-size:0.78rem; color:var(--text-dim); text-align:center;
}
.missing-placeholder a { color:var(--gold); }

/* ── ACTION ROW ── */
.arow { display:flex; gap:6px; flex-wrap:wrap; }
.clink, .alink {
  display:inline-flex; align-items:center; gap:4px;
  padding:7px 11px; border-radius:var(--radius-sm);
  font-size:0.72rem; font-weight:700; letter-spacing:.5px;
  text-decoration:none; text-transform:uppercase; min-height:34px;
  transition:all .2s;
}
.clink { background:rgba(212,168,83,.1); border:1px solid rgba(212,168,83,.4); color:var(--gold); }
.clink:active { background:rgba(212,168,83,.2); }
.alink { background:rgba(30,215,96,.08); border:1px solid rgba(30,215,96,.3); color:#1db954; }
.alink:active { background:rgba(30,215,96,.15); }

/* ── FAB ── */
.fab {
  position:fixed; bottom:18px; right:14px;
  width:44px; height:44px; background:var(--gold); border-radius:50%;
  border:none; color:#07070f; font-size:1.1rem; cursor:pointer;
  display:flex; align-items:center; justify-content:center;
  box-shadow:0 4px 20px rgba(212,168,83,.4); z-index:200;
  opacity:0; transition:opacity .3s;
}
.fab.v { opacity:1; }

/* ── COVER DIVIDER ── */
.cdivider {
  display:flex; align-items:center; gap:10px; padding:10px 6px 4px; margin-top:4px;
}
.cdline { flex:1; height:1px; background:var(--border); }
.cdlbl { font-family:'Bebas Neue',sans-serif; font-size:0.72rem; letter-spacing:3px; color:var(--text-dim); }

@media (min-width:768px) {
  .iblk { min-width:160px; }
}

/* ── MEDIA PLAYER ── */
.media-row {
  display:flex; gap:6px; flex-wrap:wrap; align-items:center;
}
.play-btn, .spotify-btn {
  display:inline-flex; align-items:center; gap:5px;
  padding:8px 13px; border-radius:var(--radius-sm);
  font-size:0.72rem; font-weight:700; letter-spacing:.5px;
  text-decoration:none; text-transform:uppercase; min-height:34px;
  cursor:pointer; transition:all .2s; border:1px solid;
  font-family:'Nunito',sans-serif;
}
.play-btn {
  background:rgba(212,168,83,.12); border-color:rgba(212,168,83,.4); color:var(--gold);
}
.play-btn:hover, .play-btn:active { background:rgba(212,168,83,.25); }
.spotify-btn {
  background:rgba(30,215,96,.1); border-color:rgba(30,215,96,.4); color:#1ed760;
}
.spotify-btn:hover, .spotify-btn:active { background:rgba(30,215,96,.22); }
.drive-player {
  width:100%; border:0; border-radius:var(--radius-sm);
  background:#000; display:block;
}
.drive-player.audio { height:80px; }
.drive-player.video { height:220px; }
.media-missing {
  font-size:0.68rem; color:var(--text-dim); font-style:italic;
  padding:8px 10px; background:var(--surface2); border-radius:var(--radius-sm);
}
.nbtn.sp { border-color:rgba(30,215,96,.4); color:#1ed760; }
.nbtn.sp:hover { background:rgba(30,215,96,.1); }
.nbtn.dr { border-color:rgba(96,165,250,.4); color:var(--blue); }
.nbtn.dr:hover { background:rgba(96,165,250,.1); }

/* ── BASS SHELL CHORD DIAGRAMS ── */
.shell-block {
  background:rgba(212,168,83,.04); border:1px solid rgba(212,168,83,.18); border-radius:var(--radius-sm);
  padding:10px 10px 12px; margin:8px 0 10px;
}
.shell-head { display:flex; align-items:baseline; gap:10px; margin-bottom:8px; }
.shell-head .ilabel { color:var(--gold); }
.shell-sub { font-size:0.65rem; color:var(--text-dim); font-style:italic; letter-spacing:.3px; }
.shell-row {
  display:grid; grid-template-columns:repeat(auto-fit,minmax(155px,1fr)); gap:8px;
}
.shell-card {
  background:rgba(0,0,0,.3); border:1px solid var(--border); border-radius:4px;
  padding:6px 6px 8px; text-align:center;
}
.shell-title {
  font-family:'Bebas Neue',sans-serif; font-size:1rem; color:var(--gold);
  letter-spacing:1.5px; line-height:1.1;
}
.shell-title .fn { font-family:'JetBrains Mono',monospace; font-size:0.65rem; color:var(--gold-dim); letter-spacing:.5px; margin-left:4px; }
.shell-svg { display:block; width:100%; max-width:150px; height:auto; margin:4px auto 2px; }
.shell-svg .str { stroke:#555; stroke-width:.7; }
.shell-svg .fret { stroke:#3a3a3a; stroke-width:.5; }
.shell-svg .nut { stroke:#8a6a28; stroke-width:1.4; }
.shell-svg .lbl { fill:#666; font-size:6px; font-family:'JetBrains Mono',monospace; }
.shell-svg .fnum { fill:#666; font-size:6.5px; font-family:'JetBrains Mono',monospace; text-anchor:middle; }
.shell-svg .dot-r { fill:#d4a853; stroke:#1a1a1a; stroke-width:1; }
.shell-svg .dot-t { fill:#4adec6; stroke:#1a1a1a; stroke-width:.8; }
.shell-svg .dot-lbl { fill:#0a0a0a; font-size:7px; font-weight:700; text-anchor:middle; font-family:Arial,sans-serif; }
.shell-form { font-size:0.62rem; color:var(--text-dim); font-family:'JetBrains Mono',monospace; letter-spacing:.3px; margin-top:2px; }
.shell-note { font-size:0.6rem; color:var(--text-dim); font-style:italic; line-height:1.4; margin-top:4px; }
</style>
  <link rel="manifest" href="/bass/manifest.webmanifest">
  <link rel="apple-touch-icon" href="/bass/icon.svg">
  <meta name="theme-color" content="#d4a853">
  <script is:inline>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', function () {
        navigator.serviceWorker.register('/bass/sw.js', { scope: '/bass/' }).catch(function () {});
      });
    }
  </script>
</head>
<body>

<div class="hdr">
  <div class="hdr-top">
    <h1>🎸 SETLIST</h1>
    <div class="hdr-meta">Hüseyin<br>27 songs · Offline</div>
  </div>
  <div class="nav">
    <button class="nbtn ao" onclick="jumpTo('s-orig')">Originals (7)</button>
    <button class="nbtn ac" onclick="jumpTo('s-cov')">Covers (20)</button>
    <button class="nbtn act" onclick="toggleAll(true)">↕ Expand</button>
    <button class="nbtn act" onclick="toggleAll(false)">↕ Collapse</button>
    <a class="nbtn sp" href="https://open.spotify.com/playlist/20BV74Tfnl2kqS8iLAbaNn" target="_blank" rel="noopener" style="text-decoration:none;display:inline-flex;align-items:center;">♫ Spotify</a>
    <a class="nbtn dr" href="https://drive.google.com/drive/u/0/folders/1swvgKfscIOWqH5kc5Klun7k-RbR7XldG" target="_blank" rel="noopener" style="text-decoration:none;display:inline-flex;align-items:center;">☁ Kayıtlar</a>
    <a class="nbtn dr" href="https://docs.google.com/document/d/17ROVDt6SBjgDhwURnvmQWDN08gpN8GcylkWuUi7qbi4/edit?tab=t.0" target="_blank" rel="noopener" style="text-decoration:none;display:inline-flex;align-items:center;">📝 Notlar</a>
  </div>
</div>

<div class="srch">
  <input type="search" placeholder="🔍  Search by title, artist, key…" oninput="filter(this.value)" autocomplete="off" autocorrect="off" spellcheck="false">
</div>

<div class="legend">
  <div class="leg"><div class="ldot" style="background:var(--green)"></div>Originals</div>
  <div class="leg"><div class="ldot" style="background:var(--blue)"></div>Covers</div>
  <div class="leg"><div class="ldot" style="background:var(--star)"></div>★ Priority</div>
  <div class="leg"><div class="ldot" style="background:var(--gold)"></div>Chord chart embedded</div>
  <div class="leg"><div class="ldot" style="background:var(--text-dim)"></div>Tap to expand</div>
</div>

<!-- ════════════════════════════ ORIGINALS ════════════════════════════ -->
<div class="section" id="s-orig">
<div class="sec-hdr">
  <span class="sec-title orig">ORIGINALS</span>
  <span class="sec-cnt">7 songs</span>
</div>

<!-- O1 · Yeniden -->
<div class="card orig-c" data-s="yeniden c g gözde berlin original">
  <div class="card-hdr" onclick="tog(this)">
    <span class="snum">O1</span>
    <div class="smain"><div class="stitle">Yeniden</div><div class="sartist">Original · Gözde Berberoğlu Özen · Berlin 2024</div></div>
    <div class="sright"><span class="dbadge">1:20</span><span class="kbadge">C / G</span><span class="xicon">▼</span></div>
  </div>
  <div class="cbody"><div class="cinner">
    <div class="key-alert">⚠️ Setlist shows <strong>C</strong> but chords are all in <strong>G major</strong> (G, Am, C, D7). Actual tonic is G — may involve capo or transposition.</div>
    <div class="irow">
      <div class="iblk"><div class="ilabel">Key Scale</div><div class="ival">G Major (Ionian)</div></div>
      <div class="iblk"><div class="ilabel">Scale Notes</div><div class="ival sc">G A B C D E F#</div><div class="itip">= relative of <b>E Minor</b> — same notes, just rooted on G</div></div>
      <div class="iblk"><div class="ilabel">G Major Pentatonic</div><div class="ival sc">G A B D E</div><div class="itip"><b>5 safest notes</b> · no semitones · use anywhere in the song</div></div>
    </div>
    <div class="shell-block">
      <div class="shell-head">
        <div class="ilabel">🎸 Bass Shell Chords — intro/verse</div>
        <div class="shell-sub">R = Root · 3/♭3 = 3rd · 5 = 5th · 7/♭7 = 7th · skip the 5 for a 2-3 note shell</div>
      </div>
      <div class="shell-row">
        <div class="shell-card">
          <div class="shell-title">G<span class="fn">Δ7 / R–3–7</span></div>
          <svg class="shell-svg" viewBox="0 0 150 75" xmlns="http://www.w3.org/2000/svg">
            <text class="lbl" x="17" y="16" text-anchor="end">G</text>
            <text class="lbl" x="17" y="30" text-anchor="end">D</text>
            <text class="lbl" x="17" y="44" text-anchor="end">A</text>
            <text class="lbl" x="17" y="58" text-anchor="end">E</text>
            <line class="str" x1="22" y1="14" x2="132" y2="14"/>
            <line class="str" x1="22" y1="28" x2="132" y2="28"/>
            <line class="str" x1="22" y1="42" x2="132" y2="42"/>
            <line class="str" x1="22" y1="56" x2="132" y2="56"/>
            <line class="fret" x1="22" y1="12" x2="22" y2="58"/>
            <line class="fret" x1="44" y1="12" x2="44" y2="58"/>
            <line class="fret" x1="66" y1="12" x2="66" y2="58"/>
            <line class="fret" x1="88" y1="12" x2="88" y2="58"/>
            <line class="fret" x1="110" y1="12" x2="110" y2="58"/>
            <line class="fret" x1="132" y1="12" x2="132" y2="58"/>
            <text class="fnum" x="33" y="68">14</text>
            <text class="fnum" x="55" y="68">15</text>
            <text class="fnum" x="77" y="68">16</text>
            <text class="fnum" x="99" y="68">17</text>
            <text class="fnum" x="121" y="68">18</text>
            <circle class="dot-r" cx="55" cy="56" r="6"/>
            <text class="dot-lbl" x="55" y="58.5">R</text>
            <circle class="dot-t" cx="77" cy="28" r="5.5"/>
            <text class="dot-lbl" x="77" y="30.5">7</text>
