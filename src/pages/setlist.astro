<script is:inline>
function tog(hdr) {
  hdr.closest('.card').classList.toggle('open');
}
function toggleAll(open) {
  document.querySelectorAll('.card').forEach(c => open ? c.classList.add('open') : c.classList.remove('open'));
}
function jumpTo(id) {
  const el = document.getElementById(id);
  if (el) window.scrollTo({ top: el.getBoundingClientRect().top + window.pageYOffset - 70, behavior: 'smooth' });
}
function filter(q) {
  q = q.toLowerCase().trim();
  document.querySelectorAll('.card').forEach(c => {
    const s = (c.dataset.s || '') + ' ' + (c.querySelector('.stitle')?.textContent || '') + ' ' + (c.querySelector('.sartist')?.textContent || '');
    c.style.display = (!q || s.toLowerCase().includes(q)) ? '' : 'none';
  });
  document.querySelectorAll('.section').forEach(sec => {
    const vis = [...sec.querySelectorAll('.card')].some(c => c.style.display !== 'none');
    sec.style.display = vis ? '' : 'none';
  });
}
window.addEventListener('scroll', () => {
  document.getElementById('fab').classList.toggle('v', window.scrollY > 200);
});

