  <div class="cbody"><div class="cinner">
    <div class="irow">
      <div class="iblk"><div class="ilabel">Key Scale</div><div class="ival">A Major</div></div>
      <div class="iblk"><div class="ilabel">A Ionian</div><div class="ival sc">A B C# D E F# G#</div><div class="itip">= A Major — <b>all chords diatonic</b>: A (I), Bm (ii), F#m (vi), E (V)</div></div>
      <div class="iblk"><div class="ilabel">A Major Pentatonic</div><div class="ival sc">A B C# E F#</div><div class="itip">= Ionian minus D/G# — <b>safe for 90s pop fills</b>, always resolves nicely</div></div>
    </div>
    <div class="irow">
      <div class="iblk"><div class="ilabel">F#m Pentatonic</div><div class="ival sc">F# A B C# E</div><div class="itip"><b>same 5 notes as A Major Pentatonic</b>, just starting on 6 — use over F#m and Bm for darker fill color</div></div>
      <div class="iblk"><div class="ilabel">Asus4 voicing</div><div class="ival sc">A D E</div><div class="itip"><b>suspended 4th</b> — resolves to A (3rd is C#); bass sits on A while guitar hangs the D</div></div>
