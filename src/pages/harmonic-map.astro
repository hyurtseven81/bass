  <a href="../setlist/">Stage Setlist ▶</a>
</nav>

</div>

<script is:inline>
// ═══════════════════════════════════════════════
// NATURAL HARMONICS — 4-STRING BASS
// ═══════════════════════════════════════════════
// Standard bass tuning: E1 A1 D2 G2
// STRING_MIDI: MIDI note numbers of the open strings
//   (E1=28, A1=33, D2=38, G2=43)
const STRING_NAMES = ['E', 'A', 'D', 'G'];
const STRING_MIDI  = [28, 33, 38, 43];
const NOTE_NAMES   = ['C', 'C♯', 'D', 'E♭', 'E', 'F', 'F♯', 'G', 'A♭', 'A', 'B♭', 'B'];

// Node positions in frets for partial k: f = 12 * log2(k / (k - m)) for m = 1..k-1
function nodePositions(k) {
  const out = [];
  for (let m = 1; m < k; m++) {
    out.push(12 * Math.log2(k / (k - m)));
  }
  return out;
}

// Pitch produced by partial k of open string (index 0..3).
// Returns { name, octave, centsOffset } where centsOffset is vs. nearest ET pitch.
function pitchForPartial(stringIdx, k) {
  const openMidi = STRING_MIDI[stringIdx];
  const semisAbove = 12 * Math.log2(k);       // exact semitones above fundamental
  const midiFloat  = openMidi + semisAbove;
  const midiRound  = Math.round(midiFloat);
  const centsOffset = (midiFloat - midiRound) * 100;
  const name   = NOTE_NAMES[((midiRound % 12) + 12) % 12];
  const octave = Math.floor(midiRound / 12) - 1;
  return { name, octave, centsOffset };
}

// ── FRETBOARD RENDERER ──
function drawFretboard(canvas, partials) {
  const ctx = canvas.getContext('2d');
  const dpr = window.devicePixelRatio || 1;

  const W = 1080, H = 210;
  canvas.width  = W * dpr;
  canvas.height = H * dpr;
  canvas.style.width  = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(dpr, dpr);

  const leftPad  = 40;
  const topPad   = 32;
  const numFrets = 24;
  const fbWidth  = W - leftPad - 40;
  const fretSpacing = fbWidth / numFrets;
  const stringSpacing = 36;

  // Background
  ctx.fillStyle = '#0a0b12';
  ctx.beginPath();
  ctx.roundRect(0, 0, W, H, 6);
  ctx.fill();

  // Nut (at fret 0)
  ctx.fillStyle = '#888';
  ctx.fillRect(leftPad - 3, topPad - 8, 4, stringSpacing * 3 + 16);

  // Fret wires
  ctx.strokeStyle = '#2a2a3a';
  ctx.lineWidth = 1;
  for (let f = 1; f <= numFrets; f++) {
    const x = leftPad + f * fretSpacing;
    ctx.beginPath();
    ctx.moveTo(x, topPad - 6);
    ctx.lineTo(x, topPad + stringSpacing * 3 + 6);
    ctx.stroke();
  }

  // Inlay markers (single at 3,5,7,9,15,17,19,21; double at 12,24)
  const singleDots = [3, 5, 7, 9, 15, 17, 19, 21];
  const doubleDots = [12, 24];
  ctx.fillStyle = '#1a1a2a';
  singleDots.forEach(f => {
    const x = leftPad + f * fretSpacing - fretSpacing / 2;
    ctx.beginPath();
    ctx.arc(x, topPad + stringSpacing * 1.5, 3.5, 0, Math.PI * 2);
    ctx.fill();
  });
  doubleDots.forEach(f => {
    const x = leftPad + f * fretSpacing - fretSpacing / 2;
    ctx.beginPath();
    ctx.arc(x, topPad + stringSpacing * 0.5, 3.5, 0, Math.PI * 2);
    ctx.fill();
    ctx.beginPath();
    ctx.arc(x, topPad + stringSpacing * 2.5, 3.5, 0, Math.PI * 2);
    ctx.fill();
  });

  // Strings — display order: G (row 0, top), D (1), A (2), E (3, bottom)
  const stringWidths = [1, 1.3, 1.8, 2.5];     // G D A E
  const displayToStringIdx = [3, 2, 1, 0];     // row 0 → string index 3 (G)
  for (let row = 0; row < 4; row++) {
    const y = topPad + row * stringSpacing;
    ctx.strokeStyle = '#4a4a55';
    ctx.lineWidth = stringWidths[row];
    ctx.beginPath();
    ctx.moveTo(leftPad, y);
    ctx.lineTo(leftPad + numFrets * fretSpacing, y);
    ctx.stroke();

    ctx.fillStyle = '#9a968e';
    ctx.font = 'bold 12px "JetBrains Mono", monospace';
    ctx.textAlign = 'right';
    ctx.textBaseline = 'middle';
    ctx.fillText(STRING_NAMES[displayToStringIdx[row]], leftPad - 10, y);
  }

  // Fret numbers under the board
  ctx.fillStyle = '#4a4a55';
  ctx.font = '9px "JetBrains Mono", monospace';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'top';
  for (let f = 1; f <= numFrets; f++) {
    const x = leftPad + f * fretSpacing - fretSpacing / 2;
    ctx.fillText(f.toString(), x, topPad + stringSpacing * 3 + 14);
  }

  // Color map per partial
  const partialColors = {
    2: '#d4a853', // gold
    3: '#4ec9b0', // teal
    4: '#5b8fd4', // blue
    5: '#9b7bd4', // purple
    6: '#8fd49b', // green
    7: '#d4637a', // rose
  };

  // Collect all nodes, then sort so lower partials render last (on top).
  // Priority: draw higher partials first → lower partials overwrite them
  // when they sit at the same fret (12, 7, 19 stacking).
  const nodes = [];
  for (let row = 0; row < 4; row++) {
    const stringIdx = displayToStringIdx[row];
    const y = topPad + row * stringSpacing;
    for (const k of partials) {
      const pitch = pitchForPartial(stringIdx, k);
      const label = pitch.name + pitch.octave;
      for (const fret of nodePositions(k)) {
        if (fret < 0.35 || fret > numFrets + 0.5) continue;
        const x = leftPad + fret * fretSpacing - fretSpacing / 2;
        nodes.push({ x, y, k, label });
      }
    }
  }
  // Draw higher partials first so lower partials end up on top at shared nodes
  nodes.sort((a, b) => b.k - a.k);

  const r = 11;
  for (const node of nodes) {
    // Outer stroke / shadow
    ctx.beginPath();
    ctx.arc(node.x, node.y, r + 1.2, 0, Math.PI * 2);
    ctx.fillStyle = '#0a0a0f';
    ctx.fill();

    // Dot
    ctx.beginPath();
    ctx.arc(node.x, node.y, r, 0, Math.PI * 2);
    ctx.fillStyle = partialColors[node.k];
    ctx.fill();

    // Pitch label
    ctx.fillStyle = '#0a0a0f';
    ctx.font = 'bold 9px "JetBrains Mono", monospace';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(node.label, node.x, node.y + 0.5);

    // Partial-number chip in upper-right corner
    ctx.beginPath();
    ctx.arc(node.x + r - 2, node.y - r + 2, 4, 0, Math.PI * 2);
    ctx.fillStyle = '#0a0a0f';
    ctx.fill();
    ctx.fillStyle = partialColors[node.k];
    ctx.font = 'bold 7px "JetBrains Mono", monospace';
    ctx.fillText(node.k.toString(), node.x + r - 2, node.y - r + 2.5);
  }
}

// ── BUILD PER-STRING PITCH TABLES ──
function buildStringTables() {
  const container = document.getElementById('string-grid');
  const strings = [
    { idx: 0, name: 'E string', openNote: 'E1 · 41.2 Hz' },
    { idx: 1, name: 'A string', openNote: 'A1 · 55.0 Hz' },
    { idx: 2, name: 'D string', openNote: 'D2 · 73.4 Hz' },
    { idx: 3, name: 'G string', openNote: 'G2 · 98.0 Hz' },
  ];

  strings.forEach(s => {
    const card = document.createElement('div');
    card.className = 'string-card';

    const rows = [];
    for (let k = 2; k <= 7; k++) {
      const pitch = pitchForPartial(s.idx, k);
      const nodes = nodePositions(k)
        .filter(f => f >= 0.35 && f <= 24.5)
        .map(f => f.toFixed(2).replace(/\.00$/, ''))
        .join(' · ');
      const cents = pitch.centsOffset;
      let centsClass = 'cents-zero';
      let centsStr = cents.toFixed(1) + '¢';
      if (Math.abs(cents) < 0.5) {
        centsClass = 'cents-zero';
        centsStr = 'exact';
      } else if (cents < 0) {
        centsClass = 'cents-flat';
        centsStr = cents.toFixed(1) + '¢';
      } else {
        centsClass = 'cents-sharp';
        centsStr = '+' + cents.toFixed(1) + '¢';
      }
      rows.push(`
        <tr>
          <td><span class="partial-chip k${k}">${k}</span></td>
          <td class="pitch">${pitch.name}${pitch.octave}</td>
          <td>${nodes}</td>
          <td class="${centsClass}">${centsStr}</td>
        </tr>
      `);
    }

    card.innerHTML = `
      <h3>${s.name}<span class="note-sub">open · ${s.openNote}</span></h3>
      <table>
        <thead>
          <tr>
            <th>k</th>
            <th>Pitch</th>
            <th>Fret nodes (≤24)</th>
            <th>vs. ET</th>
          </tr>
        </thead>
        <tbody>
          ${rows.join('')}
        </tbody>
      </table>
    `;
    container.appendChild(card);
  });
}

// ── INIT ──
document.addEventListener('DOMContentLoaded', () => {
  drawFretboard(document.getElementById('primary-fb'),  [2, 3, 4]);
  drawFretboard(document.getElementById('advanced-fb'), [5, 6, 7]);
  buildStringTables();
});
</script>
</body>
</html>
