  <!-- ============ SECTION III — BASS I ============ -->
  <section>
    <div class="section-head">
      <div class="section-num">§ III.</div>
      <h2>Per Instrument</h2>
      <div class="section-tag">protocols</div>
    </div>

    <!-- BASS I — MAYONES -->
    <div class="bass-card">
      <div class="bass-card-inner">
        <div class="bass-header">
          <div>
            <div class="bass-name">Mayones Jabba Custom 5</div>
            <div class="bass-spec">satin body · matt neck · finished maple board</div>
          </div>
          <div class="bass-roman">I</div>
        </div>

        <ul class="care-list">
          <li class="care-item">
            <div class="care-when">After Session</div>
            <div class="care-what">
              <strong>Strings:</strong> dedicated string cloth, dry, run under and over each string.<br>
              <strong>Body + neck:</strong> <span class="cloth-tag detail">Detailing</span> dry wipe.
            </div>
          </li>
          <li class="care-item">
            <div class="care-when">Weekly</div>
            <div class="care-what">
              <strong>Strings:</strong> <span class="product">GHS Fast Fret</span>, 4–5 passes per string, then wipe dry.
            </div>
          </li>
          <li class="care-item">
            <div class="care-when">Monthly</div>
            <div class="care-what">
              <strong>Body + neck + hardware:</strong> 2–3 sprays of <span class="product">MN100 Detailer</span> onto the <span class="cloth-tag detail">Detailing</span> cloth (never spray bass directly), wipe in straight lines. No buffing required.
            </div>
          </li>
          <li class="care-item">
            <div class="care-when">Twice Yearly</div>
            <div class="care-what">
              <strong>Stubborn hardware grime:</strong> dab of <span class="product">naphtha (Feuerzeugbenzin)</span> on Detailing cloth — evaporates clean.
            </div>
          </li>
        </ul>

        <div class="warning-box">
          <strong>Critical:</strong> When using Fast Fret, slide a piece of paper between strings and fretboard. Mineral oil must not contact the finished maple board.
        </div>

        <div class="diagram">
          <div class="diagram-title">Paper barrier · side view</div>
          <svg viewBox="0 0 600 220" xmlns="http://www.w3.org/2000/svg">
            <!-- Fast Fret applicator (tilted, top center) -->
            <g transform="translate(245 18) rotate(-12)">
              <rect x="0" y="0" width="110" height="34" rx="4" fill="#9c6b35" fill-opacity="0.18" stroke="#1c1410" stroke-width="1"/>
              <rect x="14" y="-10" width="14" height="10" fill="#1c1410"/>
              <text x="55" y="22" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="2" fill="#1c1410">FAST FRET</text>
            </g>
            <!-- Application sweep arrow (above strings) -->
            <path d="M 90 95 Q 300 78 510 95" stroke="#9c6b35" stroke-width="1.5" fill="none" stroke-dasharray="4,3"/>
            <polygon points="505,91 517,95 505,99" fill="#9c6b35"/>

            <!-- Strings (4 horizontal lines) -->
            <g stroke="#1c1410" stroke-width="1.6" stroke-linecap="round">
              <line x1="50" y1="108" x2="555" y2="108"/>
              <line x1="50" y1="118" x2="555" y2="118"/>
              <line x1="50" y1="128" x2="555" y2="128"/>
              <line x1="50" y1="138" x2="555" y2="138"/>
            </g>

            <!-- Paper barrier (parallelogram, slipped between strings and fretboard, corner extends beyond) -->
            <path d="M 70 148 L 540 148 L 580 142 L 580 162 L 540 168 L 70 168 Z"
                  fill="#f7f1e0" stroke="#1c1410" stroke-width="0.8"/>

            <!-- Fretboard -->
            <rect x="50" y="172" width="505" height="32" fill="#6b5847" fill-opacity="0.32" stroke="#1c1410" stroke-width="1"/>
            <!-- Fret wires -->
            <g stroke="#9c6b35" stroke-width="2.5" stroke-linecap="round">
              <line x1="135" y1="172" x2="135" y2="204"/>
              <line x1="235" y1="172" x2="235" y2="204"/>
              <line x1="335" y1="172" x2="335" y2="204"/>
              <line x1="435" y1="172" x2="435" y2="204"/>
              <line x1="525" y1="172" x2="525" y2="204"/>
            </g>

            <!-- Labels -->
            <text x="50" y="100" font-family="JetBrains Mono, monospace" font-size="9" letter-spacing="1.5" fill="#6b5847">STRINGS</text>
            <text x="592" y="155" text-anchor="end" font-family="JetBrains Mono, monospace" font-size="9" letter-spacing="1.5" fill="#7a2e1f">PAPER →</text>
            <text x="50" y="195" font-family="JetBrains Mono, monospace" font-size="9" letter-spacing="1.5" fill="#4f5a32">FRETBOARD ✓ protected</text>
          </svg>
          <div class="diagram-caption">Slip paper under the strings before applying. The applicator only ever touches strings; nothing reaches the maple.</div>
        </div>

        <div class="never-block">
          <div class="never-label">Never on this bass</div>
          <div class="never-list">
            <span class="never-item">F-One Oil</span>
            <span class="never-item">Guitar ONE</span>
            <span class="never-item">Guitar Polish</span>
            <span class="never-item">Lemon oil</span>
            <span class="never-item">Suede cloth (unused)</span>
          </div>
        </div>
      </div>
    </div>

    <!-- BASS II — TRB -->
    <div class="bass-card">
      <div class="bass-card-inner">
        <div class="bass-header">
          <div>
            <div class="bass-name">Yamaha TRB1004J</div>
            <div class="bass-spec">gloss polyurethane body · rosewood fretboard</div>
          </div>
          <div class="bass-roman">II</div>
        </div>

        <ul class="care-list">
          <li class="care-item">
            <div class="care-when">After Session</div>
            <div class="care-what">
              <strong>Strings:</strong> string cloth, dry.<br>
              <strong>Body + neck:</strong> <span class="cloth-tag detail">Detailing</span> dry wipe.
            </div>
          </li>
          <li class="care-item">
            <div class="care-when">Weekly</div>
            <div class="care-what">
              <strong>Strings:</strong> <span class="product">GHS Fast Fret</span>, then wipe dry. No paper barrier needed — rosewood tolerates it.
            </div>
          </li>
          <li class="care-item">
            <div class="care-when">Monthly</div>
            <div class="care-what">
              <strong>Body, neck, hardware:</strong> <span class="product">Guitar ONE</span> sprayed onto <span class="cloth-tag detail">Detailing</span>, wipe any direction, then <strong>buff with</strong> <span class="cloth-tag suede">Suede</span> for streak-free finish.
            </div>
          </li>
          <li class="care-item">
            <div class="care-when">Quarterly</div>
            <div class="care-what">
              <strong>Rosewood fretboard:</strong> <span class="product">F-One Oil</span> — strings off. Few drops per fret section, rub in, wait 1–2 minutes, wipe excess firmly with <span class="cloth-tag detail">Detailing</span>. Less is more.
            </div>
          </li>
          <li class="care-item">
            <div class="care-when">Twice Yearly</div>
            <div class="care-what">
              <strong>Deep clean + hardware oxidation:</strong> <span class="product">Guitar Polish</span>, pea-sized amount on <span class="cloth-tag detail">Detailing</span>, work in small sections, then buff thoroughly with <span class="cloth-tag suede">Suede</span> until haze disappears.
            </div>
          </li>
        </ul>

        <div class="diagram">
          <div class="diagram-title">F-One Oil · quarterly sequence</div>
          <div class="sequence">
            <!-- Panel 1: Drop -->
            <div class="sequence-panel">
              <svg viewBox="0 0 130 130" xmlns="http://www.w3.org/2000/svg">
                <!-- Bottle, tipped -->
                <g transform="translate(38 12) rotate(-22)">
                  <rect x="0" y="0" width="22" height="52" rx="3" fill="#9c6b35" fill-opacity="0.22" stroke="#1c1410" stroke-width="1"/>
                  <rect x="6" y="-9" width="10" height="9" fill="#1c1410"/>
                  <rect x="3" y="14" width="16" height="14" fill="#f1e9d8" stroke="#1c1410" stroke-width="0.6"/>
                  <text x="11" y="24" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="6" letter-spacing="0.8" fill="#1c1410">F-ONE</text>
                </g>
                <!-- Drops -->
                <g fill="#9c6b35">
                  <path d="M 66 64 Q 63 70 66 75 Q 69 70 66 64 Z"/>
                  <path d="M 64 78 Q 61 83 64 87 Q 67 83 64 78 Z"/>
                  <path d="M 68 90 Q 65 95 68 99 Q 71 95 68 90 Z"/>
                </g>
                <!-- Fretboard segment -->
                <rect x="18" y="102" width="94" height="20" fill="#6b5847" fill-opacity="0.4" stroke="#1c1410" stroke-width="0.8"/>
                <line x1="50" y1="102" x2="50" y2="122" stroke="#9c6b35" stroke-width="2"/>
                <line x1="84" y1="102" x2="84" y2="122" stroke="#9c6b35" stroke-width="2"/>
              </svg>
              <div class="sequence-step">i. drop</div>
              <div class="sequence-label">A few drops per fret section. Less is more.</div>
            </div>

            <!-- Panel 2: Wait -->
            <div class="sequence-panel">
              <svg viewBox="0 0 130 130" xmlns="http://www.w3.org/2000/svg">
                <!-- Hourglass frame -->
                <g stroke="#1c1410" stroke-width="1.2" fill="none" stroke-linejoin="round">
                  <path d="M 45 30 L 85 30 L 65 65 L 85 100 L 45 100 L 65 65 Z"/>
                  <line x1="42" y1="30" x2="88" y2="30" stroke-width="2.5" stroke-linecap="round"/>
                  <line x1="42" y1="100" x2="88" y2="100" stroke-width="2.5" stroke-linecap="round"/>
                </g>
                <!-- Sand top -->
                <path d="M 50 33 L 80 33 L 65 60 Z" fill="#9c6b35" fill-opacity="0.7"/>
                <!-- Sand bottom -->
                <path d="M 55 97 L 75 97 L 65 80 Z" fill="#9c6b35" fill-opacity="0.45"/>
                <!-- Falling grain -->
                <line x1="65" y1="65" x2="65" y2="78" stroke="#9c6b35" stroke-width="1"/>
                <text x="65" y="120" text-anchor="middle" font-family="Fraunces, serif" font-style="italic" font-size="13" fill="#9c6b35">1–2 min</text>
              </svg>
              <div class="sequence-step">ii. wait</div>
              <div class="sequence-label">Let the oil soak in. Do not rush.</div>
            </div>

            <!-- Panel 3: Wipe -->
            <div class="sequence-panel">
              <svg viewBox="0 0 130 130" xmlns="http://www.w3.org/2000/svg">
                <!-- Cloth (Detailing, plush) -->
                <g transform="translate(28 22) rotate(-8)">
                  <rect width="70" height="48" rx="2" fill="#4f5a32" fill-opacity="0.18" stroke="#1c1410" stroke-width="1"/>
                  <g stroke="#4f5a32" stroke-width="0.4" opacity="0.55">
                    <line x1="8" y1="10" x2="14" y2="10"/><line x1="22" y1="10" x2="28" y2="10"/><line x1="36" y1="10" x2="42" y2="10"/><line x1="50" y1="10" x2="56" y2="10"/>
                    <line x1="14" y1="22" x2="20" y2="22"/><line x1="28" y1="22" x2="34" y2="22"/><line x1="42" y1="22" x2="48" y2="22"/>
                    <line x1="8" y1="34" x2="14" y2="34"/><line x1="22" y1="34" x2="28" y2="34"/><line x1="36" y1="34" x2="42" y2="34"/><line x1="50" y1="34" x2="56" y2="34"/>
                  </g>
                </g>
                <!-- Wipe arrow -->
                <path d="M 25 88 Q 65 80 105 88" stroke="#9c6b35" stroke-width="1.5" fill="none" stroke-dasharray="3,3"/>
                <polygon points="100,84 112,88 100,92" fill="#9c6b35"/>
                <!-- Fretboard segment -->
                <rect x="18" y="102" width="94" height="20" fill="#6b5847" fill-opacity="0.4" stroke="#1c1410" stroke-width="0.8"/>
                <line x1="50" y1="102" x2="50" y2="122" stroke="#9c6b35" stroke-width="2"/>
                <line x1="84" y1="102" x2="84" y2="122" stroke="#9c6b35" stroke-width="2"/>
              </svg>
              <div class="sequence-step">iii. wipe</div>
              <div class="sequence-label">Wipe excess firmly with Detailing cloth.</div>
            </div>
          </div>
          <div class="diagram-caption">Strings off first. Same sequence on the SLB ebony — but use even less.</div>
        </div>
      </div>
    </div>

    <!-- BASS III — SLB -->
    <div class="bass-card">
      <div class="bass-card-inner">
        <div class="bass-header">
          <div>
            <div class="bass-name">Yamaha SLB100 Silent Upright</div>
            <div class="bass-spec">gloss polyurethane body · ebony fretboard · piezo bridge</div>
          </div>
          <div class="bass-roman">III</div>
        </div>

        <ul class="care-list">
          <li class="care-item">
            <div class="care-when">After Session</div>
            <div class="care-what">
              <strong>Strings:</strong> string cloth, full length including bow contact area.<br>
              <strong>Body:</strong> <span class="cloth-tag detail">Detailing</span> dry wipe.<br>
              <strong>If bowed:</strong> separate cloth for rosin dust.
            </div>
          </li>
          <li class="care-item">
            <div class="care-when">Weekly</div>
            <div class="care-what">
              <strong>Strings — pizz portion only:</strong> <span class="product">GHS Fast Fret</span>. Skip entirely if you primarily bow.
            </div>
          </li>
          <li class="care-item">
            <div class="care-when">Monthly</div>
            <div class="care-what">
              <strong>Body + neck:</strong> <span class="product">Guitar ONE</span> on <span class="cloth-tag detail">Detailing</span>, buff with <span class="cloth-tag suede">Suede</span>. Apply product to cloth in a separate location — never spray near electronics.
            </div>
          </li>
          <li class="care-item">
            <div class="care-when">Quarterly</div>
            <div class="care-what">
              <strong>Ebony fretboard:</strong> <span class="product">F-One Oil</span> — strings off. Sparingly, less than rosewood needs. Wipe excess firmly with <span class="cloth-tag detail">Detailing</span>.
            </div>
          </li>
          <li class="care-item">
            <div class="care-when">Twice Yearly</div>
            <div class="care-what">
              <strong>Body + hardware:</strong> <span class="product">Guitar Polish</span> on <span class="cloth-tag detail">Detailing</span>, buff with <span class="cloth-tag suede">Suede</span>.
            </div>
          </li>
        </ul>

        <div class="warning-box">
          <strong>Critical:</strong> Never apply Fast Fret to the bowing area — it kills rosin grip. Avoid liquid contact with piezo bridge, jack, and preamp.
        </div>

        <div class="diagram">
          <div class="diagram-title">SLB100 · zones to protect</div>
          <svg viewBox="0 0 600 220" xmlns="http://www.w3.org/2000/svg">
            <!-- Schematic body outline -->
            <rect x="40" y="55" width="520" height="110" rx="10" fill="#e7dcc4" fill-opacity="0.6" stroke="#1c1410" stroke-width="1.2"/>

