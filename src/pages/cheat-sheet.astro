    htSub.textContent = 'Chords: ' + s.chords.join(', ');
    htCanvases.innerHTML = '<canvas id="ht-cv"></canvas>';
    drawFretboard(document.getElementById('ht-cv'), s);
    tip.classList.add('visible');
    positionTip(e);
  }

  // ── Render chord into tooltip ──
  function showChord(key, e) {
    const c = CHORDS[key];
    if (!c) return;
    if (activeKey === 'c:' + key) { positionTip(e); return; }
    activeKey = 'c:' + key;
    htName.textContent = c.name + '  ' + c.symbol;
    htFormula.textContent = c.formula;
    htSub.textContent = c.shell;
    htCanvases.innerHTML =
      '<div><div class="ht-vlabel">E-root</div><canvas id="ht-ce"></canvas></div>' +
      '<div><div class="ht-vlabel">A-root</div><canvas id="ht-ca"></canvas></div>';
    drawChordVoicing(document.getElementById('ht-ce'), c.eRoot, 3);
    drawChordVoicing(document.getElementById('ht-ca'), c.aRoot, 3);
    tip.classList.add('visible');
    positionTip(e);
  }

  function hideTip() {
    hideTimer = setTimeout(() => {
      tip.classList.remove('visible');
      activeKey = null;
    }, 120);
  }

  function cancelHide() { clearTimeout(hideTimer); }

  // ── Try to resolve text to a scale or chord key ──
  function resolve(text) {
    const t = text.trim();
    // Try exact
    if (scaleTextMap[t]) return { type: 'scale', key: scaleTextMap[t] };
    if (chordTextMap[t] && chordTextMap[t] !== null) return { type: 'chord', key: chordTextMap[t] };
    // Try case-insensitive
    const tl = t.toLowerCase();
    if (scaleTextMap[tl]) return { type: 'scale', key: scaleTextMap[tl] };
    // Null means it maps to a scale instead
    if (chordTextMap[t] === null && scaleTextMap[t]) return { type: 'scale', key: scaleTextMap[t] };
    return null;
  }

  // ── Attach to an element ──
  function attach(el, type, key) {
    el.classList.add('hz');
    el.addEventListener('mouseenter', (e) => {
      cancelHide();
      if (type === 'scale') showScale(key, e);
      else showChord(key, e);
    });
    el.addEventListener('mousemove', positionTip);
    el.addEventListener('mouseleave', hideTip);
  }

  // ═══ 1. Chord tags in scale cards (Section I) ═══
  // Show chord voicing if a match exists.
  // If no chord match, show scale ONLY if it's a different scale than the parent card.
  // If it would show the same scale the user is already looking at, skip it.
  const scaleContainer = document.getElementById('scale-cards');
  if (scaleContainer) {
    const scaleKeys = Object.keys(SCALES);
    const scaleCards = scaleContainer.querySelectorAll('.card');
    scaleCards.forEach((card, i) => {
      if (!scaleKeys[i]) return;
      const parentScaleKey = scaleKeys[i];
      card.querySelectorAll('.tag').forEach(tag => {
        const text = tag.textContent.trim();
        // Try chord voicing first
        const chordKey = chordTextMap[text];
        if (chordKey && chordKey !== null) {
          attach(tag, 'chord', chordKey);
          return;
        }
        // Try scale — but only if it's a DIFFERENT scale
        const scaleKey = scaleTextMap[text];
        if (scaleKey && scaleKey !== parentScaleKey) {
          attach(tag, 'scale', scaleKey);
        }
        // Otherwise: same scale or no match — don't attach (no redundant tooltip)
      });
    });
  }

  // ═══ 2. Chord tags in chord cards (Section II) ═══
  // (chord cards don't have .tag elements to hover, skip)

  // ═══ 3. Reference table — Section III ═══
  const refRows = document.querySelectorAll('.ref-table tbody tr');
  const refRowScales = [
    ['Ionian', 'Lydian'],
    ['Dorian', 'Aeolian', 'Phrygian'],
    ['Mixolydian', 'Bebop Dom', 'Lydian Dom'],
    ['Altered', 'Dim HW', 'Whole Tone'],
    ['Melodic Minor', 'Harmonic Minor'],
    ['Locrian', 'Locrian ♮2'],
    ['Diminished WH'],
    ['Mixolydian', 'Dorian']
  ];
  const refRowChords = ['maj7','min7','dom7',null,'minMaj7','halfDim','dim7','sus4'];

  refRows.forEach((row, i) => {
    if (i >= refRowChords.length) return;
    const cells = row.querySelectorAll('td');
    // Cell 0: chord name — make hoverable
    if (cells[0] && refRowChords[i]) {
      attach(cells[0], 'chord', refRowChords[i]);
    }
    // Cell 1: symbol — make hoverable
    if (cells[1] && refRowChords[i]) {
      attach(cells[1], 'chord', refRowChords[i]);
    }
    // Cell 2: scale choices — wrap each scale name
    if (cells[2] && refRowScales[i]) {
      const origText = cells[2].textContent;
      const parts = origText.split(',').map(s => s.trim());
      const html = parts.map(name => {
        const r = resolve(name);
        if (r) return '<span class="hz" data-ht="' + r.type + ':' + r.key + '">' + name + '</span>';
        return name;
      }).join(', ');
      cells[2].innerHTML = html;
    }
  });

  // ═══ 4. Section IV — Practical Situations ═══
  // Scan text nodes in .when-box and .card-desc for known terms
  const sectIV = document.querySelectorAll('.scale-grid .card .when-box, .scale-grid .card .card-desc');
  wrapKnownTerms(sectIV);

  // ═══ 5. Section V — Artist Breakdown ═══
  const sectV = document.querySelectorAll('.artist-section .tech-card .td, .artist-section .tech-card .detail, .artist-section .tech-card .tags-row .tag');
  // Tags in artist section
  document.querySelectorAll('.artist-section .tag').forEach(tag => {
    const text = tag.textContent.trim();
    const r = resolve(text);
    if (r) attach(tag, r.type, r.key);
  });
  // Text in tech cards
  const artistText = document.querySelectorAll('.artist-section .tech-card .td, .artist-section .tech-card .detail');
  wrapKnownTerms(artistText);

  // ═══ 6. Section VI — Comparison ═══
  const cmpText = document.querySelectorAll('.cmp-col li, .cmp-center span');
  wrapKnownTerms(cmpText);

  // ═══ Bind dynamically created .hz[data-ht] elements ═══
  document.querySelectorAll('.hz[data-ht]').forEach(el => {
    const [type, key] = el.dataset.ht.split(':');
    el.addEventListener('mouseenter', (e) => {
      cancelHide();
      if (type === 'scale') showScale(key, e);
      else showChord(key, e);
    });
    el.addEventListener('mousemove', positionTip);
    el.addEventListener('mouseleave', hideTip);
  });

  // ── ESC to dismiss ──
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') { tip.classList.remove('visible'); activeKey = null; }
  });

  // ═══ Helper: scan elements and wrap known scale/chord terms ═══
  function wrapKnownTerms(elements) {
    // Build sorted term list (longest first to avoid partial matches)
    const allTerms = [];
    Object.keys(scaleTextMap).forEach(t => { if (t.length > 2) allTerms.push(t); });
    Object.keys(chordTextMap).forEach(t => { if (t.length > 2 && chordTextMap[t] !== null) allTerms.push(t); });
    // Deduplicate and sort longest first
    const unique = [...new Set(allTerms)].sort((a, b) => b.length - a.length);
    // Build regex
    const escaped = unique.map(t => t.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'));
    if (escaped.length === 0) return;
    const re = new RegExp('\\b(' + escaped.join('|') + ')\\b', 'g');

    elements.forEach(el => {
      // Don't process elements that already have .hz children or are tags
      if (el.classList.contains('hz') || el.classList.contains('tag')) return;
      // Walk text nodes
      const walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, null);
      const textNodes = [];
      let node;
      while (node = walker.nextNode()) {
        if (node.parentElement.classList.contains('hz')) continue; // skip already wrapped
        if (node.textContent.trim().length > 2) textNodes.push(node);
      }
      textNodes.forEach(tn => {
        const text = tn.textContent;
        if (!re.test(text)) return;
        re.lastIndex = 0;
        const frag = document.createDocumentFragment();
        let lastIdx = 0;
        let match;
        re.lastIndex = 0;
        while ((match = re.exec(text)) !== null) {
          const r = resolve(match[1]);
          if (!r) continue;
          // Text before match
          if (match.index > lastIdx) {
            frag.appendChild(document.createTextNode(text.slice(lastIdx, match.index)));
          }
          const span = document.createElement('span');
          span.className = 'hz';
          span.dataset.ht = r.type + ':' + r.key;
          span.textContent = match[1];
          frag.appendChild(span);
          lastIdx = match.index + match[1].length;
        }
        if (lastIdx === 0) return; // no matches replaced
        if (lastIdx < text.length) {
          frag.appendChild(document.createTextNode(text.slice(lastIdx)));
        }
        tn.parentNode.replaceChild(frag, tn);
      });
    });

    // Bind newly created spans
    document.querySelectorAll('.hz[data-ht]').forEach(el => {
      if (el._htBound) return;
      el._htBound = true;
      const [type, key] = el.dataset.ht.split(':');
      el.addEventListener('mouseenter', (e) => {
        cancelHide();
        if (type === 'scale') showScale(key, e);
        else showChord(key, e);
      });
      el.addEventListener('mousemove', positionTip);
      el.addEventListener('mouseleave', hideTip);
    });
  }
}
</script>

</body>
</html>

