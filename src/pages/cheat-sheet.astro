// ── DRAW MINI CHORD VOICING ON CANVAS ──
function drawChordVoicing(canvas, voicingNotes, rootFret) {
  const ctx = canvas.getContext('2d');
  const dpr = window.devicePixelRatio || 1;
  const W = 200, H = 110;
  canvas.width = W * dpr;
  canvas.height = H * dpr;
  canvas.style.width = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(dpr, dpr);

  // Compute absolute fret positions
  const notes = voicingNotes.map(([strIdx, offset, label, type]) => ({
    strIdx, fret: rootFret + offset, label, type, displayRow: 3 - strIdx
  }));

  // Determine fret range to display
  const allFrets = notes.map(n => n.fret);
  const minFret = Math.max(0, Math.min(...allFrets) - 1);
  const maxFret = Math.max(minFret + 4, Math.max(...allFrets) + 1);
  const showFrets = maxFret - minFret + 1;

  // Layout
  const leftPad = 22;
  const topPad = 16;
  const rightPad = 8;
  const fretSpacing = (W - leftPad - rightPad) / showFrets;
  const stringSpacing = 20;
  const displayStrings = [3, 2, 1, 0]; // G, D, A, E top to bottom

  // Background
  ctx.fillStyle = '#0a0b12';
  ctx.beginPath();
  ctx.roundRect(0, 0, W, H, 5);
  ctx.fill();

  // Nut (only if fret 0/1 visible)
  if (minFret <= 1) {
    const nutX = leftPad + (1 - minFret) * fretSpacing;
    ctx.fillStyle = '#555';
    ctx.fillRect(nutX - 1.5, topPad - 3, 3, stringSpacing * 3 + 6);
  }

  // Fret wires
  ctx.strokeStyle = '#2a2a3a';
  ctx.lineWidth = 1;
  for (let i = 1; i <= showFrets; i++) {
    const f = minFret + i;
    const x = leftPad + i * fretSpacing;
    ctx.beginPath();
    ctx.moveTo(x, topPad - 3);
    ctx.lineTo(x, topPad + stringSpacing * 3 + 3);
    ctx.stroke();
  }

  // Fret dots (3,5,7,9,12)
  const dotFrets = [3,5,7,9,12];
  ctx.fillStyle = '#1a1a2a';
  dotFrets.forEach(df => {
    if (df > minFret && df <= minFret + showFrets) {
      const idx = df - minFret;
      const x = leftPad + idx * fretSpacing - fretSpacing / 2;
      ctx.beginPath();
      ctx.arc(x, topPad + stringSpacing * 1.5, 3, 0, Math.PI * 2);
      ctx.fill();
    }
  });

  // Strings
  const stringWidths = [1, 1.2, 1.6, 2.2];
  for (let i = 0; i < 4; i++) {
    const y = topPad + i * stringSpacing;
    ctx.strokeStyle = '#3a3a48';
    ctx.lineWidth = stringWidths[i];
    const startX = leftPad + (minFret <= 1 ? (1 - minFret) * fretSpacing : 0);
    ctx.beginPath();
    ctx.moveTo(startX, y);
    ctx.lineTo(W - rightPad, y);
    ctx.stroke();

    // String label
    ctx.fillStyle = '#3a3a4a';
    ctx.font = '9px "JetBrains Mono", monospace';
    ctx.textAlign = 'right';
    ctx.textBaseline = 'middle';
    ctx.fillText(STRING_NAMES[displayStrings[i]], leftPad - 5, y);
  }

  // Fret numbers
  ctx.fillStyle = '#3a3a4a';
  ctx.font = '8px "JetBrains Mono", monospace';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'top';
  for (let i = 0; i < showFrets; i++) {
    const f = minFret + i + 1;
    if (f > 0) {
      const x = leftPad + (i + 1) * fretSpacing - fretSpacing / 2;
      ctx.fillText(f.toString(), x, topPad + stringSpacing * 3 + 8);
    }
  }

  // Colors
  const typeColors = {
    root: '#d4a853',
    chord: '#4ec9b0',
    tension: '#9b7bd4'
  };

  // Muted strings marker (X)
  const usedStrings = new Set(notes.map(n => n.displayRow));
  ctx.fillStyle = '#333340';
  ctx.font = '9px "JetBrains Mono", monospace';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  for (let i = 0; i < 4; i++) {
    if (!usedStrings.has(i)) {
      const y = topPad + i * stringSpacing;
      ctx.fillText('×', leftPad - 5, y);
    }
  }

  // Draw notes
  notes.forEach(note => {
    const fretIdx = note.fret - minFret;
    const x = leftPad + fretIdx * fretSpacing + fretSpacing / 2;
    const y = topPad + note.displayRow * stringSpacing;
    const r = 9;
    const color = typeColors[note.type] || '#888';

    // Outer glow for root
    if (note.type === 'root') {
      ctx.beginPath();
      ctx.arc(x, y, r + 2, 0, Math.PI * 2);
      ctx.strokeStyle = color + '44';
      ctx.lineWidth = 2;
      ctx.stroke();
    }

    // Circle
    ctx.beginPath();
    ctx.arc(x, y, r, 0, Math.PI * 2);
    ctx.fillStyle = color;
    ctx.fill();

    // Label
    ctx.fillStyle = '#0a0a0f';
    ctx.font = 'bold 7.5px "JetBrains Mono", monospace';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(note.label, x, y + 0.5);
  });
}

// ── BUILD CHORD VOICING CARDS ──
function buildChordCards() {
  const container = document.getElementById('chord-cards');
  if (!container) return;

  const eRootFret = 3; // Root at fret 3 on E string
  const aRootFret = 3; // Root at fret 3 on A string

  Object.entries(CHORDS).forEach(([key, chord]) => {
    const card = document.createElement('div');
    card.className = 'chord-card';

    card.innerHTML = `
      <h3>${chord.name}<span class="chord-sym">${chord.symbol}</span></h3>
      <div class="chord-formula">${chord.formula}</div>
      <div class="chord-shell">${chord.shell}</div>
      <div class="chord-desc"><em>${chord.sound}</em></div>
      <div class="voicing-pair">
        <div class="voicing-box">
          <div class="voicing-label">E-String Root</div>
          <canvas class="e-voicing"></canvas>
        </div>
        <div class="voicing-box">
          <div class="voicing-label">A-String Root</div>
          <canvas class="a-voicing"></canvas>
