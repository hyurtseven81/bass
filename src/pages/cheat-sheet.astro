<!-- HADRIEN FERAUD LICKS -->
<h3 style="font-family:'Playfair Display',serif;font-size:20px;color:var(--hadrien);margin-bottom:16px;">Hadrien Feraud — Licks</h3>

<div class="lick-card hf-lick">
  <h4>Lick 1: Altered Dominant Sweep — G7alt → CMaj7</h4>
  <div class="lick-meta">
    <span>G Altered scale (A♭ melodic minor)</span>
    <span class="ctx ctx-fast" style="background:rgba(224,96,80,0.15);color:#e08070;border:1px solid rgba(224,96,80,0.25)">Fast V→I</span>
