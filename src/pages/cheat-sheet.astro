  });
}

// ── DRAW FRETBOARD ON CANVAS ──
function drawFretboard(canvas, scaleData) {
  const ctx = canvas.getContext('2d');
  const dpr = window.devicePixelRatio || 1;

  const W = 520, H = 140;
  canvas.width = W * dpr;
  canvas.height = H * dpr;
  canvas.style.width = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(dpr, dpr);

  // Layout
  const leftPad = 30;
  const topPad = 24;
  const fretSpacing = 44;
  const stringSpacing = 24;
  const numFrets = 10;

  // Background
  ctx.fillStyle = '#0a0b12';
  ctx.beginPath();
  ctx.roundRect(0, 0, W, H, 6);
  ctx.fill();

  // Nut
  ctx.fillStyle = '#555';
  ctx.fillRect(leftPad + fretSpacing - 2, topPad - 4, 4, stringSpacing * 3 + 8);

  // Fret wires
  ctx.strokeStyle = '#2a2a3a';
  ctx.lineWidth = 1;
  for (let f = 2; f <= numFrets; f++) {
    const x = leftPad + f * fretSpacing;
    ctx.beginPath();
    ctx.moveTo(x, topPad - 4);
    ctx.lineTo(x, topPad + stringSpacing * 3 + 4);
    ctx.stroke();
  }

  // Fret dots (markers at frets 3, 5, 7, 9)
  const dotFrets = [3, 5, 7, 9];
  ctx.fillStyle = '#1a1a2a';
  dotFrets.forEach(f => {
    if (f <= numFrets) {
      const x = leftPad + f * fretSpacing + fretSpacing / 2;
      ctx.beginPath();
      ctx.arc(x, topPad + stringSpacing * 1.5, 4, 0, Math.PI * 2);
      ctx.fill();
    }
  });

  // Strings (G=top, D, A, E=bottom)
  const stringWidths = [1, 1.3, 1.8, 2.4]; // G, D, A, E
  const displayStrings = [3, 2, 1, 0]; // top to bottom: G(15), D(10), A(5), E(0)

  for (let i = 0; i < 4; i++) {
    const y = topPad + i * stringSpacing;
    ctx.strokeStyle = '#4a4a55';
    ctx.lineWidth = stringWidths[i];
    ctx.beginPath();
    ctx.moveTo(leftPad + fretSpacing, y);
    ctx.lineTo(leftPad + numFrets * fretSpacing, y);
    ctx.stroke();

    // String label
    ctx.fillStyle = '#4a4a55';
    ctx.font = '10px "JetBrains Mono", monospace';
    ctx.textAlign = 'right';
    ctx.textBaseline = 'middle';
    ctx.fillText(STRING_NAMES[displayStrings[i]], leftPad + fretSpacing - 10, y);
  }

  // Fret numbers
  ctx.fillStyle = '#3a3a4a';
  ctx.font = '9px "JetBrains Mono", monospace';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'top';
  for (let f = 1; f <= numFrets; f++) {
    const x = leftPad + f * fretSpacing + fretSpacing / 2;
    ctx.fillText(f.toString(), x, topPad + stringSpacing * 3 + 12);
  }

  // Colors for note types
  const typeColors = {
    root: '#d4a853',
    chord: '#4ec9b0',
    scale: '#5b8fd4',
    tension: '#9b7bd4',
    chromatic: '#d4637a'
  };

  // Place notes on fretboard
  // We place the root at fret 3 on the E string (bottom string, displayed at row index 3)
  // Root fret position
  const rootFret = 3;

  // For each note in the scale, find valid fret positions across strings
  // A note at semitone offset `s` from root can be played at:
  //   string `str` (offset = STRING_OFFSETS[str]), fret = rootFret + s - (STRING_OFFSETS[str] - STRING_OFFSETS[0])
  // Simplify: fret = rootFret + s - STRING_OFFSETS[str] + STRING_OFFSETS[0]
  //         = rootFret + s - STRING_OFFSETS[str]   (since STRING_OFFSETS[0] = 0)

  const placedNotes = [];

  scaleData.notes.forEach(([semitones, label, type]) => {
    // Try all octaves (0, 12) to get more coverage
    [0, 12].forEach(octaveShift => {
      const s = semitones + octaveShift;
      for (let strIdx = 0; strIdx < 4; strIdx++) {
        const fret = rootFret + s - STRING_OFFSETS[strIdx];
        if (fret >= 1 && fret <= numFrets - 1) {
          // Display row: G=0, D=1, A=2, E=3 → displayRow = 3 - strIdx
          const displayRow = 3 - strIdx;

          // Check for duplicate position
          const key = `${displayRow}-${fret}`;
          if (!placedNotes.find(n => `${n.row}-${n.fret}` === key)) {
            placedNotes.push({
              row: displayRow,
              fret: fret,
              label: label,
              type: octaveShift > 0 && type === 'root' ? 'root' : type,
              octave: octaveShift > 0 ? 1 : 0
            });
          }
        }
      }
    });
  });

  // Draw notes
  placedNotes.forEach(note => {
    const x = leftPad + note.fret * fretSpacing + fretSpacing / 2;
    const y = topPad + note.row * stringSpacing;
    const r = 10;

    const color = typeColors[note.type] || '#888';

    // Circle
    ctx.beginPath();
    ctx.arc(x, y, r, 0, Math.PI * 2);
    ctx.fillStyle = note.octave > 0 ? color + '88' : color;
    ctx.fill();

    // Label
    ctx.fillStyle = '#0a0a0f';
    ctx.font = 'bold 8px "JetBrains Mono", monospace';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(note.label, x, y + 0.5);
  });
}

// ── BUILD FRETBOARD CARDS ──
function buildFretboardCards() {
  const container = document.getElementById('scale-cards');

  Object.entries(SCALES).forEach(([key, scale]) => {
    const card = document.createElement('div');
    card.className = 'card';

    const altNameHTML = scale.altName ? ` <span class="alt-name">(${scale.altName})</span>` : '';
    const tagsHTML = scale.chords.map((c, i) => {
      const t = scale.chordTypes[i];
      const cls = t === 'min' ? 'tag-min' : t === 'dom' ? 'tag-dom' : t === 'dim' ? 'tag-dim' : t === 'alt' ? 'tag-alt' : 'tag-maj';
      return `<span class="tag ${cls}">${c}</span>`;
    }).join('');

    card.innerHTML = `
      <h3>${scale.name}${altNameHTML}</h3>
      <div class="formula">${scale.formula}</div>
      <div class="chord-tags">${tagsHTML}</div>
      <div class="fb-container"><canvas></canvas></div>
      <div class="when-box">${scale.when}</div>
    `;

    container.appendChild(card);

    const canvas = card.querySelector('canvas');
    drawFretboard(canvas, scale);
  });
}

