    let y = e.clientY + pad;
    // Keep on screen
    if (x + tw > window.innerWidth - 8) x = e.clientX - tw - pad;
    if (y + th > window.innerHeight - 8) y = e.clientY - th - pad;
    if (x < 4) x = 4;
